  font-size: 15px;
  outline: none;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}
.ssInput::placeholder {
  color: var(--color-text-faint);
}
.ssInput:focus {
  border-color: var(--color-accent);
  box-shadow: 0 0 0 3px rgba(131, 40, 249, 0.25), var(--shadow-glow-sm);
}
