<file path="app/globals.css">
@import "tailwindcss";

@theme {
  --font-sans: var(--font-inter), sans-serif;
  --font-mono: var(--font-jetbrains-mono), monospace;

  /* Radius scale - Qubi style floating & airy */
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 16px;
  --radius-xl: 24px;
  --radius-pill: 9999px;

  /* ── Main Canvas (Light, Airy) ── */
  --color-bg: #FCFCFD;
  --color-surface: #FFFFFF;
  --color-border: #F3F4F6;
  --color-text-primary: #111827;
  --color-text-muted: #6B7280;
  --color-text-faint: #9CA3AF;

  /* ── Sidebar (Deep Dark) ── */
  --color-sidebar-bg: #18181B;
  --color-sidebar-surface: #27272A;
  --color-sidebar-hover: #3F3F46;
  --color-sidebar-border: #3F3F46;
  --color-sidebar-text: #F4F4F5;
  --color-sidebar-muted: #A1A1AA;

  /* ── Accents (Qubi Style) ── */
  --color-accent-lime: #D9F99D;
  --color-accent-lime-hover: #bef264;
  --color-accent-lavender: #F3E8FF;
  --color-accent-cyan: #67E8F9;
  
  /* Primary Action Button (using Lime) */
  --color-accent: var(--color-accent-lime);
  --color-accent-text: #064E3B; /* Dark green text on lime */
  --color-accent-hover: var(--color-accent-lime-hover);

  /* ── Chat Bubbles ── */
  --color-user-bubble: #FAF5FF; /* Soft purple */
  --color-user-bubble-border: #E9D5FF;
  
  /* ── Secondary Button ── */
  --color-secondary-btn: #F3F4F6;
  --color-secondary-btn-text: #374151;
}

:root {
  color-scheme: light;

  /* Shadows - Soft, airy */
  --shadow-input: 0 2px 10px rgba(0, 0, 0, 0.05), 0 0 0 1px rgba(0, 0, 0, 0.02);
  --shadow-card: 0 4px 24px rgba(0, 0, 0, 0.04), 0 0 0 1px rgba(0, 0, 0, 0.02);
  --shadow-glow-sm: 0 0 12px rgba(243, 232, 255, 0.5);
  --shadow-glow-md: 0 8px 24px rgba(243, 232, 255, 0.8);
  --shadow-glow-lg: 0 16px 48px rgba(243, 232, 255, 1);

  /* Glass - Light */
  --glass-bg: rgba(255, 255, 255, 0.8);
  --glass-bg-hover: rgba(255, 255, 255, 0.95);
  --glass-border: rgba(0, 0, 0, 0.05);
  --glass-border-faint: rgba(0, 0, 0, 0.02);
  --glass-shadow: rgba(0, 0, 0, 0.04);

  /* Landing-specific */
  --shadow-accent: rgba(217, 249, 157, 0.4);
  --shadow-accent-soft: rgba(243, 232, 255, 0.5);
  --color-status: #10B981; /* Green status indicator */
  --color-beta-bg: rgba(0, 0, 0, 0.05);
  --color-beta-border: rgba(0, 0, 0, 0.1);
  --color-accent-dim: rgba(0, 0, 0, 0.05);
  --color-feature-hover: rgba(0, 0, 0, 0.02);
  --color-cta-bg: #FFFFFF;
  --color-cta-border: #F3F4F6;
}

body {
  background-color: var(--color-bg);
  color: var(--color-text-primary);
  font-family: var(--font-sans);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ================================================
   SCROLLBAR
   ================================================ */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--color-border); border-radius: 2px; }
::-webkit-scrollbar-thumb:hover { background: var(--color-text-faint); }

.sidebar-scroll::-webkit-scrollbar-thumb { background: var(--color-sidebar-border); }
.sidebar-scroll::-webkit-scrollbar-thumb:hover { background: var(--color-sidebar-muted); }

/* ================================================
   GLOBAL BUTTONS
   ================================================ */
.btnPrimary {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--color-accent); color: var(--color-accent-text);
  font-weight: 600; font-size: 14px; padding: 10px 20px; border-radius: var(--radius-sm);
  text-decoration: none; transition: background 0.15s, transform 0.15s, box-shadow 0.15s;
  border: 1px solid transparent; cursor: pointer;
}
.btnPrimary:hover { background: var(--color-accent-hover); box-shadow: 0 0 12px rgba(255,255,255,0.2); }
.btnPrimary:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; }

.btnSecondary {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--color-secondary-btn); color: var(--color-secondary-btn-text);
  font-weight: 500; font-size: 14px; padding: 10px 20px; border-radius: var(--radius-sm);
  text-decoration: none; transition: background 0.15s, border-color 0.15s;
  border: 1px solid var(--color-border); cursor: pointer;
}
.btnSecondary:hover { border-color: var(--color-text-faint); background: #27272A; }

.btnPill {
  display: inline-flex; align-items: center; gap: 7px;
  background: var(--color-surface); color: var(--color-text-primary); font-weight: 600; font-size: 14px;
  padding: 8px 16px; border-radius: var(--radius-sm); text-decoration: none;
  border: 1px solid var(--color-border); transition: background 0.15s, border-color 0.15s;
  cursor: pointer;
}
.btnPill:hover { background: #1E1E20; border-color: var(--color-text-muted); }

.btnPrimaryLg {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--color-accent); color: var(--color-accent-text);
  font-weight: 600; font-size: 15px; padding: 14px 26px; border-radius: var(--radius-sm);
  text-decoration: none; transition: background 0.2s, box-shadow 0.2s;
  cursor: pointer;
}
.btnPrimaryLg:hover {
  background: var(--color-accent-hover);
  box-shadow: 0 0 20px rgba(255,255,255,0.15);
}
.btnPrimaryLg:disabled { opacity: 0.5; cursor: not-allowed; }

.btnGhost {
  display: inline-flex; align-items: center; gap: 7px;
  background: transparent; color: var(--color-text-muted); font-weight: 500; font-size: 14.5px;
  padding: 10px 20px; border-radius: var(--radius-sm); text-decoration: none;
  border: 1px solid transparent; transition: color 0.15s, background 0.15s; cursor: pointer;
}
.btnGhost:hover { color: var(--color-text-primary); background: var(--color-surface); }

/* Unified Avatar */
.avatar-gradient {
  background: #141414;
  border: 1px solid var(--color-border);
}

/* ================================================
   GLOBAL INPUTS
   ================================================ */
.ssInput {
  width: 100%;
  padding: 12px 16px;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  color: var(--color-text-primary);
  font-size: 15px;
  outline: none;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}
.ssInput::placeholder { color: var(--color-text-faint); }
.ssInput:focus {
  border-color: var(--color-text-muted);
  box-shadow: 0 0 0 1px var(--color-text-muted);
}

/* Chrome autofill override */
.ssInput:-webkit-autofill,
.ssInput:-webkit-autofill:hover,
.ssInput:-webkit-autofill:focus {
  -webkit-text-fill-color: var(--color-text-primary);
  -webkit-box-shadow: 0 0 0px 1000px var(--color-surface) inset;
  box-shadow: 0 0 0px 1000px var(--color-surface) inset;
  transition: background-color 9999s ease-in-out 0s;
  caret-color: var(--color-text-primary);
}

/* ================================================
   CHAT BUBBLES (In-app)
   ================================================ */
.bubbleUser {
  align-self: flex-end; background: var(--color-user-bubble); color: var(--color-text-primary);
  border: 1px solid var(--color-user-bubble-border);
  border-radius: var(--radius-md) var(--radius-md) 2px var(--radius-md);
}
.bubbleClone {
  align-self: flex-start; background: transparent; color: var(--color-text-primary);
  border-left: 2px solid var(--color-border);
  padding-left: 16px;
  border-radius: 0;
}

@keyframes ssMessageIn {
  from { opacity: 0; transform: translateY(4px); }
  to { opacity: 1; transform: translateY(0); }
}
.ssMessage { animation: ssMessageIn 0.25s ease-out; }

.typingCursor {
  display: inline-block;
  width: 8px;
  height: 16px;
  background: var(--color-text-muted);
  animation: blink 1s step-end infinite;
  vertical-align: middle;
  margin-left: 8px;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

/* ================================================
   LANDING PAGE — NAV
   ================================================ */
.ssNav {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 40px; position: sticky; top: 0; z-index: 100;
  background: rgba(255,255,255,0.85); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
  border-bottom: 1px solid var(--color-border);
}
.ssNav .wrap {
  display: flex; align-items: center; justify-content: space-between; height: 60px;
}
.logo { display: flex; align-items: center; gap: 12px; }
.logoMark {
  width: 24px; height: 24px; flex-shrink: 0;
  background: var(--color-text-primary);
  clip-path: polygon(0 0, 100% 0, 100% 45%, 0 45%, 0 55%, 100% 55%, 100% 100%, 0 100%);
}
.logoText { font-weight: 700; font-size: 17px; letter-spacing: -0.03em; color: var(--color-text-primary); text-transform: uppercase; }
.betaTag {
  font-size: 9px; font-weight: 700; letter-spacing: 0.1em;
  color: var(--color-text-muted); background: var(--color-surface);
  padding: 3px 8px; border-radius: 2px; margin-left: 6px;
  border: 1px solid var(--color-border); text-transform: uppercase;
}
.navLinks { display: flex; align-items: center; gap: 32px; }
.navLinks a { text-decoration: none; font-size: 13px; font-weight: 500; color: var(--color-text-muted); transition: color 0.2s ease; text-transform: uppercase; letter-spacing: 0.05em; }
.navLinks a:hover { color: var(--color-text-primary); }

/* ================================================
   LANDING PAGE — HERO
   ================================================ */
.heroSection {
  position: relative; padding: 120px 0 80px; text-align: center; overflow: hidden;
}
.eyebrow {
  position: relative; display: inline-block;
  font-size: 12px; font-weight: 600; color: var(--color-text-muted);
  background: var(--color-surface); padding: 6px 16px; border-radius: 2px;
  border: 1px solid var(--color-border);
  margin-bottom: 32px; text-transform: uppercase; letter-spacing: 0.1em;
}
.starkHeading {
  position: relative;
  font-size: clamp(48px, 7vw, 84px); font-weight: 800; letter-spacing: -0.05em;
  line-height: 1.0; max-width: 900px; margin: 0 auto;
  color: var(--color-text-primary);
}
.heroSub {
  position: relative;
  font-size: 18px; color: var(--color-text-muted); max-width: 600px;
  margin: 32px auto 0; line-height: 1.6; font-weight: 400;
}
.heroActions {
  display: flex; gap: 16px; margin-top: 48px; justify-content: center;
  position: relative; z-index: 10;
}

/* ================================================
   LANDING PAGE — CHAT MOCKUP
   ================================================ */
.chatCard {
  margin: 80px auto 0; max-width: 640px;
  background: var(--color-surface); border-radius: var(--radius-lg);
  border: 1px solid var(--color-border);
  text-align: left; overflow: hidden;
  box-shadow: 0 32px 64px -16px rgba(0,0,0,0.8);
}
.chatHead {
  display: flex; align-items: center; gap: 12px;
  padding: 16px 24px; border-bottom: 1px solid var(--color-border);
  background: var(--color-bg);
}
.chatAvatar {
  width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0;
  background: var(--color-text-primary);
}
.chatName { font-weight: 600; font-size: 13px; color: var(--color-text-primary); text-transform: uppercase; letter-spacing: 0.05em; }
.chatStatus {
  display: flex; align-items: center; gap: 8px; font-size: 11px; color: var(--color-text-faint); margin-left: auto; text-transform: uppercase; letter-spacing: 0.05em;
}
.chatDot { width: 6px; height: 6px; background: var(--color-text-muted); }
.chatBody {
  padding: 32px; display: flex; flex-direction: column; gap: 24px;
  min-height: 280px; background: var(--color-surface); position: relative; overflow: hidden;
}

/* Landing page chat bubbles */
.chatBody .bubble {
  font-size: 14px; line-height: 1.6; max-width: 85%;
  opacity: 0; animation: fadeInBubble 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}
.chatBody .bubble.user {
  background: var(--color-user-bubble); border: 1px solid var(--color-user-bubble-border);
  padding: 12px 16px; border-radius: var(--radius-sm);
  color: var(--color-text-primary); align-self: flex-end;
}
.chatBody .bubble.clone {
  background: transparent; border: none; border-left: 2px solid var(--color-border);
  color: var(--color-text-primary); align-self: flex-start;
  padding: 4px 0 4px 16px;
}
.chatBody .bubble.typing {
  background: transparent; border: none; padding: 4px 0 4px 16px; align-self: flex-start;
}
.chatBody .bubble.user2 {
  background: var(--color-user-bubble); border: 1px solid var(--color-user-bubble-border);
  padding: 12px 16px; border-radius: var(--radius-sm);
  color: var(--color-text-primary); align-self: flex-end;
}

.chatInputMock {
  display: flex; align-items: center; gap: 12px;
  margin: 0 24px 24px; padding: 12px 16px;
  border: 1px solid var(--color-border); border-radius: var(--radius-sm);
  background: var(--color-surface);
}
.chatInputMock > span:first-child { font-size: 13px; color: var(--color-text-faint); flex: 1; font-family: var(--font-mono); }
.chatSend {
  width: 24px; height: 24px; background: var(--color-text-primary);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0; border-radius: 2px;
}

/* ================================================
   LANDING PAGE — SECTIONS
   ================================================ */
.ssSection { padding: 120px 0; position: relative; z-index: 10; border-top: 1px solid var(--color-border); }
.sectionHead { text-align: center; max-width: 640px; margin: 0 auto 64px; }
.sectionLabel {
  font-size: 12px; font-weight: 600; color: var(--color-text-muted); margin-bottom: 24px; display: block; text-transform: uppercase; letter-spacing: 0.1em;
}
.sectionTitle {
  font-size: clamp(32px, 5vw, 48px); font-weight: 800; letter-spacing: -0.04em; color: var(--color-text-primary); line-height: 1.1;
}
.sectionSub {
  font-size: 16px; color: var(--color-text-muted); line-height: 1.7; margin-top: 24px;
}

/* Sharp Card Utility (Landing) */
.sharpCard {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  transition: all 0.2s ease;
}
.sharpCard:hover {
  box-shadow: var(--shadow-card);
}

/* Steps / Grid */
.bentoGrid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
}
.bentoCard { padding: 40px; display: flex; flex-direction: column; }
.bentoIcon {
  width: 48px; height: 48px; background: var(--color-surface);
  border: 1px solid var(--color-border); border-radius: 2px;
  display: flex; align-items: center; justify-content: center;
  color: var(--color-text-primary); margin-bottom: 32px;
}
.bentoCard h3 { font-size: 18px; font-weight: 700; margin-bottom: 16px; color: var(--color-text-primary); letter-spacing: -0.02em; }
.bentoCard p { font-size: 15px; color: var(--color-text-muted); line-height: 1.6; }

/* Final CTA */
.finalCta {
  max-width: 800px; margin: 0 auto; padding: 80px 40px;
  text-align: center; background: var(--color-surface);
  border-radius: var(--radius-xl); border: 1px solid var(--color-border);
  position: relative; overflow: hidden;
}

/* Footer */
.ssFooter {
  border-top: 1px solid var(--color-border); padding: 64px 0;
  color: var(--color-text-faint); font-size: 13px;
}
.ssFooter .wrap {
  display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 24px;
}
.footerLinks { display: flex; gap: 32px; }
.footerLinks a { color: var(--color-text-muted); text-decoration: none; transition: color 0.2s ease; font-weight: 500; }
.footerLinks a:hover { color: var(--color-text-primary); }

/* ================================================
   LAYOUT UTILITIES
   ================================================ */
.wrap {
  max-width: 1200px; margin-left: auto; margin-right: auto;
  padding-left: 40px; padding-right: 40px;
}

/* Name Gate Styles */
.nameGateCard {
  width: 100%; max-width: 480px; text-align: left;
  background: var(--color-surface); border: 1px solid var(--color-border); padding: 48px;
  border-radius: var(--radius-xl); box-shadow: var(--shadow-card);
}
.nameGateTitle { font-size: 24px; font-weight: 700; color: var(--color-text-primary); margin-bottom: 12px; letter-spacing: -0.02em; }
.nameGateDesc { color: var(--color-text-muted); font-size: 15px; margin-bottom: 32px; line-height: 1.6; }
.nameGateForm { display: flex; gap: 16px; }
.nameGateInput {
  flex: 1; background: var(--color-surface); border: 1px solid var(--color-border);
  border-radius: var(--radius-sm); padding: 12px 16px;
  color: var(--color-text-primary); font-size: 15px;
  outline: none; transition: border-color 0.2s;
}
.nameGateInput:focus { border-color: var(--color-text-muted); }

/* ================================================
   ANIMATIONS
   ================================================ */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(16px); }
  to { opacity: 1; transform: translateY(0); }
}
.animate-fade-in-up {
  animation: fadeInUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

/* ================================================
   RESPONSIVE
   ================================================ */
@media (max-width: 768px) {
  .navLinks a:not(:last-child) { display: none; }
  .bentoGrid { grid-template-columns: 1fr; }
  .finalCta { padding: 64px 24px; }
  .nameGateForm { flex-direction: column; }
}

/* ================================================
   QUBI AESTHETIC UTILITIES
   ================================================ */
.ambient-mesh {
  position: relative;
}
.ambient-mesh::before {
  content: "";
  position: absolute;
  top: -150px; left: -100px;
  width: 600px; height: 600px;
  background: radial-gradient(circle, var(--color-accent-lavender) 0%, transparent 60%);
  opacity: 0.7;
  filter: blur(80px);
  z-index: -1;
  pointer-events: none;
}
.ambient-mesh::after {
  content: "";
  position: absolute;
  top: -50px; right: -150px;
  width: 500px; height: 500px;
  background: radial-gradient(circle, #FCE7F3 0%, transparent 60%); /* Soft pink */
  opacity: 0.5;
  filter: blur(80px);
  z-index: -1;
  pointer-events: none;
}
