                  <p className="text-sm text-text-muted mb-5">Permanently delete your account and all associated cognitive data, memories, and personality profiles. This action is irreversible.</p>
                  {!deleteConfirm ? (
                    <button
                      onClick={() => setDeleteConfirm(true)}
