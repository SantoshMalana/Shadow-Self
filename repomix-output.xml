                  }`}
                >
                  {tab === 'provenance' ? 'Cognitive Provenance' : tab === 'journeys' ? `Decisions (${data.journeys.length})` : 'Consent Log'}
                </button>
              ))}
            </div>

            {/* Tab Content */}
            {activeTab === 'provenance' && (
