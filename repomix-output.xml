@import "tailwindcss";

@theme {
  --font-sans: var(--font-inter), sans-serif;
  --font-mono: var(--font-jetbrains-mono), monospace;

  /* Radius scale */
  --radius-sm: 10px;
  --radius-md: 14px;
  --radius-lg: 20px;
  --radius-pill: 999px;

  /* DIRECT DARK MODE COLORS for Tailwind v4 to generate bg-bg, text-text-primary, etc. */
  --color-bg: #07040d;
  --color-card: #140f20;
  --color-surface: #1c1530;
  --color-border: #2b2145;
  --color-text-primary: #f7f5fc;
  --color-text-muted: #bcb3d6;
  --color-text-faint: #8f84ab;
  --color-accent: #8328f9;
  --color-accent-deep: #4c1594;
  --color-accent-light: #d6b8ff;
  --color-accent-hover: #6f1edb;
  --color-accent-soft: #23153f;
}

:root {
  /* Force dark system scrollbars and defaults */
  color-scheme: dark;

  /* Glassmorphism Variables */
  --glass-bg: rgba(255, 255, 255, 0.02);
  --glass-bg-hover: rgba(255, 255, 255, 0.05);
  --glass-border: rgba(255, 255, 255, 0.1);
  --glass-border-faint: rgba(255, 255, 255, 0.05);
  --glass-shadow: rgba(0, 0, 0, 0.4);

  /* Accent glow */
  --shadow-glow-sm: 0 0 8px rgba(131, 40, 249, 0.45);
  --shadow-glow-md: 0 4px 16px -4px rgba(131, 40, 249, 0.55);
  --shadow-glow-lg: 0 10px 34px -10px rgba(131, 40, 249, 0.75);
}

/* ====== SCROLLBAR ====== */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--color-surface); border-radius: 2px; }
::-webkit-scrollbar-thumb:hover { background: var(--color-text-faint); }

.chat-scroll { overflow-y: auto; scroll-behavior: smooth; }
.chat-scroll::-webkit-scrollbar { width: 4px; }
.chat-scroll::-webkit-scrollbar-thumb { background: var(--color-surface); border-radius: 2px; }

/* Mobile menu slide-in animation */
@keyframes slideInRight {
  from { transform: translateX(100%); }
  to { transform: translateX(0); }
}

/* ====== CONSOLIDATED FROM MODULES ====== */

/* From page.module.css */
/* ====== ANIMATIONS ====== */
@keyframes float {
  0% { transform: translateY(0px); }
  50% { transform: translateY(-12px); }
  100% { transform: translateY(0px); }
}

@keyframes gradientShift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

@keyframes fadeInBubble {
  0% { opacity: 0; transform: translateY(10px) scale(0.98); }
  100% { opacity: 1; transform: translateY(0) scale(1); }
}

/* ====== LIGHT RAYS ====== */
.lightFx {
  position: fixed;
  inset: 0;
  z-index: 0;
  overflow: hidden;
  pointer-events: none;
}
.raySource {
  position: absolute;
  top: -240px;
  right: -240px;
  width: 560px;
  height: 560px;
  border-radius: 50%;
  background: radial-gradient(circle, #ffffff 0%, var(--color-accent) 32%, transparent 70%);
  filter: blur(80px);
  opacity: 0.55;
  animation: float 8s ease-in-out infinite;
}
.rays {
  position: absolute;
  top: -55%;
  right: -55%;
  width: 160%;
  height: 160%;
  background: conic-gradient(from 205deg at 100% 0%,
    transparent 0deg, rgba(214,184,255,0.32) 4deg, transparent 11deg,
    transparent 27deg, rgba(214,184,255,0.20) 31deg, transparent 38deg,
    transparent 0deg, var(--color-ray-1) 4deg, transparent 11deg,
    transparent 27deg, var(--color-ray-2) 31deg, transparent 38deg,
    transparent 59deg, var(--color-ray-3) 63deg, transparent 69deg,
    transparent 85deg, var(--color-ray-4) 89deg, transparent 96deg,
    transparent 130deg
  );
  -webkit-mask-image: radial-gradient(circle at 100% 0%, black 0%, black 22%, transparent 62%);
  mask-image: radial-gradient(circle at 100% 0%, black 0%, black 22%, transparent 62%);
  mix-blend-mode: screen;
  filter: blur(1.5px);
}

/* ====== NAV ====== */
.ssNav {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 40px; position: sticky; top: 0; z-index: 100;
  background: var(--color-bg); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--glass-border-faint);
}
.ssNav .wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 68px;
}
.logo { display: flex; align-items: center; gap: 9px; }
.logoMark {
  width: 26px; height: 26px; border-radius: 50%; flex-shrink: 0;
  background: radial-gradient(circle at 32% 28%, #ffffff, #c084fc 35%, #8328f9 78%);
  box-shadow: 0 0 12px var(--shadow-accent);
}
.logoText { font-weight: 700; font-size: 16.5px; letter-spacing: -0.01em; }
.betaTag {
  font-size: 9.5px; font-weight: 600; letter-spacing: 0.06em;
  color: var(--color-accent-light); background: var(--color-beta-bg);
  padding: 2px 7px; border-radius: var(--radius-pill); margin-left: 6px;
  border: 1px solid var(--color-beta-border);
}
.navLinks { display: flex; align-items: center; gap: 28px; }
.navLinks a { text-decoration: none; font-size: 14px; color: var(--color-text-muted); transition: color 0.2s ease; }
.navLinks a:hover { color: var(--color-text-primary); }

/* ====== HERO ====== */
.heroSection {
  position: relative;
  padding: 96px 0 64px;
  text-align: center;
  overflow: hidden;
}
.eyebrow {
  position: relative; display: inline-block;
  font-size: 13px; font-weight: 600; color: var(--color-accent-light);
  background: var(--glass-bg-hover); padding: 6px 16px; border-radius: var(--radius-pill);
  border: 1px solid var(--glass-border);
  margin-bottom: 26px;
}
.gradientHeading {
  position: relative;
  font-size: clamp(38px, 5.5vw, 64px); font-weight: 800; letter-spacing: -0.03em;
  line-height: 1.1; max-width: 800px; margin: 0 auto;
  background: linear-gradient(110deg, #ffffff 0%, #ffffff 40%, var(--color-accent-light) 70%, var(--color-accent) 100%);
  background-size: 200% auto;
  -webkit-background-clip: text; background-clip: text;
  color: transparent; -webkit-text-fill-color: transparent;
  animation: gradientShift 8s ease infinite;
}
.heroSub {
  position: relative;
  font-size: 18px; color: var(--color-text-muted); max-width: 560px;
  margin: 24px auto 0; line-height: 1.6;
}
.heroActions {
  display: flex; gap: 16px; margin-top: 40px; justify-content: center;
  position: relative; z-index: 10;
}

/* ====== CHAT MOCKUP ====== */
.chatCard {
  margin: 64px auto 0;
  max-width: 600px;
  background: var(--color-bg);
  border-radius: var(--radius-lg);
  border: 1px solid var(--glass-border-faint);
  text-align: left;
  overflow: hidden;
  animation: float 6s ease-in-out infinite;
}
.chatHead {
  display: flex; align-items: center; gap: 12px;
  padding: 16px 20px; border-bottom: 1px solid var(--glass-border-faint);
  background: var(--glass-bg);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
}
.chatAvatar {
  width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0;
  background: radial-gradient(circle at 32% 28%, #ffffff, #c084fc 35%, #8328f9 78%);
  box-shadow: 0 0 12px var(--shadow-accent);
}
.chatName { font-weight: 600; font-size: 14px; }
.chatStatus {
  display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--color-text-faint); margin-left: auto;
}
.chatDot { width: 6px; height: 6px; border-radius: 50%; background: var(--color-status); box-shadow: 0 0 8px var(--color-status); }
.chatBody {
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  min-height: 240px;
  background: var(--color-card);
  position: relative;
  overflow: hidden;
  border-left: 1px solid var(--glass-border); 
  border-right: 1px solid var(--glass-border); 
  box-shadow: 0 32px 80px -20px var(--glass-shadow), 0 0 0 1px var(--border-chat-ring), 0 8px 32px var(--shadow-chat-soft);
}

.bubble {
  padding: 12px 16px;
  font-size: 14.5px;
  line-height: 1.5;
  max-width: 85%;
  opacity: 0;
  animation: fadeInBubble 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}
.bubble.user {
  background: var(--glass-bg-hover);
  border: 1px solid var(--glass-border);
  color: var(--color-text-primary);
  border-radius: 16px 16px 4px 16px;
  align-self: flex-end;
}
.bubble.clone {
  background: linear-gradient(135deg, var(--glass-bg-hover) 0%, var(--glass-bg) 100%);
  border: 1px solid var(--glass-border);
  color: var(--color-text-primary);
  border-radius: 16px 16px 16px 4px;
  align-self: flex-start;
  box-shadow: 0 4px 12px var(--glass-shadow);
}
.bubble.typing {
  background: transparent;
  border: none;
  box-shadow: none;
  padding: 8px 12px;
  color: var(--color-text-faint);
  font-size: 24px;
  letter-spacing: 2px;
  line-height: 0.5;
}
.bubble.user2 {
  background: var(--glass-bg-hover);
  border: 1px solid var(--glass-border);
  color: var(--color-text-primary);
  border-radius: 16px 16px 4px 16px;
  align-self: flex-end;
}

.chatInputMock {
  display: flex; align-items: center; gap: 10px;
  margin: 0 20px 20px; padding: 12px 10px 12px 18px;
  border: 1px solid var(--glass-border); 
  border-radius: 24px; 
  background: var(--glass-shadow);
}
.chatInputMock > span:first-child { font-size: 14px; color: var(--color-text-faint); flex: 1; }
.chatSend {
  width: 32px; height: 32px; border-radius: 50%; background: var(--color-accent);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  box-shadow: 0 2px 8px var(--shadow-accent);
}

/* ====== SECTIONS ====== */
.ssSection { padding: 96px 0; position: relative; z-index: 10; }
.sectionHead { text-align: center; max-width: 560px; margin: 0 auto 56px; }
.sectionLabel {
  font-size: 14px; font-weight: 600; color: var(--color-accent-light); margin-bottom: 16px; display: block;
}
.sectionTitle {
  font-size: clamp(28px, 4vw, 38px); font-weight: 700; letter-spacing: -0.02em;
}

/* ====== GLASS CARD UTILITY ====== */
.glassCard {
  background: var(--glass-bg);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--glass-border-faint);
  border-radius: var(--radius-lg);
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}
.glassCard:hover {
  background: var(--glass-border-faint);
  border-color: var(--color-accent-dim);
  transform: translateY(-4px);
  box-shadow: 0 12px 24px -10px var(--glass-shadow), 0 0 20px var(--shadow-accent-soft);
}

/* ====== STEPS ====== */
.stepsGrid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
  border-top: 1px solid var(--glass-border-faint); padding-top: 72px;
}
.stepCard {
  padding: 32px;
}
.stepNum {
  width: 36px; height: 36px; border-radius: 50%; background: var(--glass-bg-hover);
  color: var(--color-accent-light); display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 15px; margin-bottom: 24px;
  border: 1px solid var(--glass-border);
  box-shadow: 0 0 12px var(--glass-shadow);
}
.stepCard h3 { font-size: 18px; font-weight: 600; margin-bottom: 12px; }
