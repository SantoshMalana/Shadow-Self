  text-decoration: none; transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
  box-shadow: 0 10px 34px -10px rgba(131,40,249,0.35); cursor: pointer;
}
.btnPrimaryLg:hover {
  background: var(--color-accent-deep);
  transform: translateY(-1px);
  box-shadow: 0 14px 42px -8px rgba(131,40,249,0.5);
}
.btnPrimaryLg:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

.btnGhost {
  display: inline-flex; align-items: center; gap: 7px;
  background: transparent; color: var(--color-text-muted); font-weight: 500; font-size: 14.5px;
  padding: 10px 20px; border-radius: var(--radius-pill); text-decoration: none;
  border: 1px solid var(--color-border); transition: color 0.15s, border-color 0.15s; cursor: pointer;
}
.btnGhost:hover { color: var(--color-text-primary); border-color: var(--color-text-muted); }

/* ================================================
   GLOBAL INPUTS
   ================================================ */
.ssInput {
  width: 100%;
  padding: 14px 16px 14px 48px;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  color: var(--color-text-primary);
  font-size: 15px;
  outline: none;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}
.ssInput::placeholder { color: var(--color-text-faint); }
.ssInput:focus {
  border-color: var(--color-accent-purple);
  background: #FFFFFF;
  box-shadow: 0 0 0 3px rgba(131, 40, 249, 0.1);
}

/* Chrome autofill override */
.ssInput:-webkit-autofill,
.ssInput:-webkit-autofill:hover,
.ssInput:-webkit-autofill:focus {
  -webkit-text-fill-color: var(--color-text-primary);
  -webkit-box-shadow: 0 0 0px 1000px var(--color-surface) inset;
  box-shadow: 0 0 0px 1000px var(--color-surface) inset;
  transition: background-color 9999s ease-in-out 0s;
  caret-color: var(--color-text-primary);
}

/* ================================================
   CHAT BUBBLES (In-app)
   ================================================ */
.bubbleUser {
  align-self: flex-end; background: var(--color-user-bubble); color: var(--color-text-primary);
  border: 1px solid var(--color-user-bubble-border);
  border-bottom-right-radius: 4px;
}
.bubbleClone {
  align-self: flex-start; background: #FFFFFF; color: var(--color-text-primary);
  border: 1px solid var(--color-border);
  border-bottom-left-radius: 4px;
  box-shadow: 0 2px 6px rgba(0,0,0,0.03);
}

@keyframes ssMessageIn {
  from { opacity: 0; transform: translateY(4px); }
  to { opacity: 1; transform: translateY(0); }
}
.ssMessage { animation: ssMessageIn 0.25s ease-out; }

.typingDot {
  width: 5px; height: 5px; border-radius: 50%; background: var(--color-text-muted);
  animation: dotBounce 1.2s ease infinite;
}
.typingDot:nth-child(2) { animation-delay: 0.2s; }
.typingDot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotBounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* ================================================
   LANDING PAGE ΓÇö NAV
   ================================================ */
.ssNav {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 40px; position: sticky; top: 0; z-index: 100;
  background: rgba(255,255,255,0.85); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
  border-bottom: 1px solid var(--glass-border-faint);
  transition: all 0.3s ease;
}
.ssNav .wrap {
  display: flex; align-items: center; justify-content: space-between; height: 68px;
}
.logo { display: flex; align-items: center; gap: 9px; }
.logoMark {
  width: 26px; height: 26px; border-radius: 50%; flex-shrink: 0;
  background: radial-gradient(circle at 32% 28%, #ffffff, var(--color-accent-light) 35%, var(--color-accent-purple) 78%);
  box-shadow: 0 0 12px var(--shadow-accent);
}
.logoText { font-weight: 700; font-size: 16.5px; letter-spacing: -0.01em; color: var(--color-text-primary); }
.betaTag {
  font-size: 9.5px; font-weight: 600; letter-spacing: 0.06em;
  color: var(--color-accent-purple); background: var(--color-beta-bg);
  padding: 2px 7px; border-radius: var(--radius-pill); margin-left: 6px;
  border: 1px solid var(--color-beta-border);
}
.navLinks { display: flex; align-items: center; gap: 28px; }
.navLinks a { text-decoration: none; font-size: 14px; color: var(--color-text-muted); transition: color 0.2s ease; }
.navLinks a:hover { color: var(--color-text-primary); }

/* ================================================
   LANDING PAGE ΓÇö HERO
   ================================================ */
.heroSection {
  position: relative; padding: 96px 0 64px; text-align: center; overflow: hidden;
}
.eyebrow {
  position: relative; display: inline-block;
  font-size: 13px; font-weight: 600; color: var(--color-accent-purple);
  background: var(--color-accent-soft); padding: 6px 16px; border-radius: var(--radius-pill);
  border: 1px solid rgba(131, 40, 249, 0.12);
  margin-bottom: 26px;
}
.gradientHeading {
  position: relative;
  font-size: clamp(42px, 6vw, 72px); font-weight: 800; letter-spacing: -0.04em;
  line-height: 1.05; max-width: 860px; margin: 0 auto;
  background: linear-gradient(110deg, #111827 0%, #111827 40%, var(--color-accent-purple) 70%, var(--color-accent-deep) 100%);
  background-size: 200% auto;
  -webkit-background-clip: text; background-clip: text;
  color: transparent; -webkit-text-fill-color: transparent;
  animation: gradientShift 8s ease infinite;
}
@keyframes gradientShift {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}
.heroSub {
  position: relative;
  font-size: 18px; color: var(--color-text-muted); max-width: 560px;
  margin: 24px auto 0; line-height: 1.6;
}
.heroActions {
  display: flex; gap: 16px; margin-top: 40px; justify-content: center;
  position: relative; z-index: 10;
}

/* ================================================
   LANDING PAGE ΓÇö CHAT MOCKUP
   ================================================ */
.chatCard {
  margin: 64px auto 0; max-width: 600px;
  background: #FFFFFF; border-radius: var(--radius-lg);
  border: 1px solid var(--color-border);
  text-align: left; overflow: hidden;
  animation: float 6s ease-in-out infinite;
  box-shadow: 0 24px 60px -20px rgba(0,0,0,0.1);
}
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}
@keyframes fadeInBubble {
  from { opacity: 0; transform: translateY(6px); }
  to { opacity: 1; transform: translateY(0); }
}
.chatHead {
  display: flex; align-items: center; gap: 12px;
  padding: 16px 20px; border-bottom: 1px solid var(--color-border);
  background: var(--color-card);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
}
.chatAvatar {
  width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0;
  background: radial-gradient(circle at 32% 28%, #ffffff, var(--color-accent-light) 35%, var(--color-accent-purple) 78%);
  box-shadow: 0 0 12px var(--shadow-accent);
}
.chatName { font-weight: 600; font-size: 14px; color: var(--color-text-primary); }
.chatStatus {
  display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--color-text-faint); margin-left: auto;
}
.chatDot { width: 6px; height: 6px; border-radius: 50%; background: var(--color-status); box-shadow: 0 0 8px var(--color-status); }
.chatBody {
  padding: 24px; display: flex; flex-direction: column; gap: 16px;
  min-height: 240px; background: #FFFFFF; position: relative; overflow: hidden;
}

/* Landing page chat bubbles */
.chatBody .bubble {
  padding: 12px 16px; font-size: 14.5px; line-height: 1.5; max-width: 85%;
  opacity: 0; animation: fadeInBubble 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}
.chatBody .bubble.user {
  background: var(--color-user-bubble); border: 1px solid var(--color-user-bubble-border);
  color: var(--color-text-primary); border-radius: 16px 16px 4px 16px; align-self: flex-end;
}
.chatBody .bubble.clone {
  background: transparent; border: none;
  color: var(--color-text-primary); align-self: flex-start;
  box-shadow: none; padding: 12px 16px 12px 0;
}
.chatBody .bubble.typing {
  background: transparent; border: none; box-shadow: none;
  padding: 8px 12px; color: var(--color-text-faint);
  font-size: 24px; letter-spacing: 2px; line-height: 0.5;
}
.chatBody .bubble.user2 {
  background: var(--color-user-bubble); border: 1px solid var(--color-user-bubble-border);
  color: var(--color-text-primary); border-radius: 16px 16px 4px 16px; align-self: flex-end;
}

.chatInputMock {
  display: flex; align-items: center; gap: 10px;
  margin: 0 20px 20px; padding: 10px 10px 10px 20px;
  border: 1px solid var(--color-border); border-radius: 32px;
  background: rgba(255,255,255,0.9); backdrop-filter: blur(12px);
  box-shadow: var(--shadow-input);
}
.chatInputMock > span:first-child { font-size: 14px; color: var(--color-text-faint); flex: 1; }
.chatSend {
  width: 32px; height: 32px; border-radius: 50%; background: var(--color-accent-purple);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  box-shadow: 0 2px 8px var(--shadow-accent);
}

/* ================================================
   LANDING PAGE ΓÇö SECTIONS
   ================================================ */
.ssSection { padding: 96px 0; position: relative; z-index: 10; }
.sectionHead { text-align: center; max-width: 560px; margin: 0 auto 56px; }
.sectionLabel {
  font-size: 14px; font-weight: 600; color: var(--color-accent-purple); margin-bottom: 16px; display: block;
}
.sectionTitle {
  font-size: clamp(28px, 4vw, 38px); font-weight: 700; letter-spacing: -0.02em; color: var(--color-text-primary);
}
.sectionSub {
  font-size: 16px; color: var(--color-text-muted); line-height: 1.7;
}

/* Glass Card Utility (Landing) */
.glassCard {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(0, 0, 0, 0.04);
  border-radius: var(--radius-xl);
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  box-shadow: 0 4px 14px rgba(0, 0, 0, 0.03), 0 0 0 1px rgba(0,0,0,0.02);
}
.glassCard:hover {
  border-color: rgba(131, 40, 249, 0.15);
  transform: translateY(-4px);
  box-shadow: 0 16px 32px -12px rgba(131, 40, 249, 0.15), 0 0 24px rgba(131, 40, 249, 0.06);
  background: rgba(255, 255, 255, 0.9);
}

.glow-button {
  position: relative;
  background: linear-gradient(135deg, var(--color-accent-purple), var(--color-accent-deep));
  color: white;
  border-radius: var(--radius-pill);
  transition: all 0.2s ease;
  z-index: 1;
}
.glow-button::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  border-radius: inherit;
  background: inherit;
  filter: blur(12px);
  opacity: 0.6;
  z-index: -1;
  transition: opacity 0.2s ease;
}
.glow-button:hover {
  transform: translateY(-1px);
}
.glow-button:hover::before {
  opacity: 0.9;
}

/* Steps */
.stepsGrid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
  border-top: 1px solid var(--color-border); padding-top: 72px;
}
.stepCard { padding: 32px; }
.stepNum {
  width: 36px; height: 36px; border-radius: 50%; background: var(--color-accent-soft);
  color: var(--color-accent-purple); display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 15px; margin-bottom: 24px;
  border: 1px solid rgba(131,40,249,0.12);
}
.stepCard h3 { font-size: 18px; font-weight: 600; margin-bottom: 12px; color: var(--color-text-primary); }
.stepCard p { font-size: 15px; color: var(--color-text-muted); line-height: 1.6; }

/* Features */
.featuresGrid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
.featureCard { display: flex; gap: 20px; padding: 28px; }
.featureDot {
  width: 48px; height: 48px; border-radius: var(--radius-md);
  background: var(--color-surface); display: flex; align-items: center; justify-content: center;
  font-size: 20px; border: 1px solid var(--color-border);
  transition: all 0.3s ease;
}
.featureCard:hover .featureDot {
  background: var(--color-feature-hover);
  border-color: var(--color-accent-dim);
}
.featureCard h3 { font-size: 16px; font-weight: 600; margin-bottom: 8px; color: var(--color-text-primary); }
.featureCard p { font-size: 14px; color: var(--color-text-muted); line-height: 1.6; }

/* Use Cases */
.useCasesGrid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.useCaseCard { padding: 32px; display: flex; flex-direction: column; }
.useCaseCard h3 { font-size: 18px; font-weight: 600; margin-bottom: 12px; color: var(--color-text-primary); }
.useCaseCard p { font-size: 15px; color: var(--color-text-muted); line-height: 1.6; flex: 1; }

/* Trust */
.trustGrid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
.trustCard { padding: 28px; text-align: center; }
.trustCard h3 { font-size: 15px; font-weight: 600; margin-bottom: 10px; color: var(--color-text-primary); }
.trustCard p { font-size: 14px; color: var(--color-text-muted); line-height: 1.6; }

/* Final CTA */
.finalCta {
  max-width: 800px; margin: 0 auto; padding: 64px 20px;
  text-align: center; background: var(--color-cta-bg);
  border-radius: var(--radius-lg); border: 1px solid var(--color-cta-border);
  position: relative; overflow: hidden;
}

/* Footer */
.ssFooter {
  border-top: 1px solid var(--color-border); padding: 40px 0; margin-top: 40px;
  text-align: center; color: var(--color-text-faint); font-size: 14px;
}
.ssFooter .wrap {
  display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px;
}
.footerLinks { display: flex; gap: 28px; }
.footerLinks a { font-size: 14px; color: var(--color-text-faint); text-decoration: none; transition: color 0.2s ease; }
.footerLinks a:hover { color: var(--color-text-primary); }

/* ================================================
   LAYOUT UTILITIES
   ================================================ */
.wrap {
  max-width: 1040px; margin-left: auto; margin-right: auto;
  padding-left: 32px; padding-right: 32px;
}
.wrapSm { max-width: 520px; margin-left: auto; margin-right: auto; }
.wrapMd { max-width: 720px; margin-left: auto; margin-right: auto; }
.centerText { text-align: center; }

/* ================================================
   LIGHT FX (Landing page radial glow)
   ================================================ */
.lightFx {
  position: fixed; inset: 0; z-index: 0; pointer-events: none; overflow: hidden;
}
.raySource {
  position: absolute; top: -20%; left: 50%; transform: translateX(-50%);
  width: 600px; height: 600px;
  background: radial-gradient(circle, rgba(131,40,249,0.06) 0%, transparent 70%);
  border-radius: 50%;
}
.rays {
  position: absolute; top: 0; left: 50%; transform: translateX(-50%);
  width: 100%; height: 100%;
  background: linear-gradient(180deg, rgba(131,40,249,0.03) 0%, transparent 40%);
}

/* Name Gate Styles */
.nameGateCard {
  width: 100%; max-width: 440px; text-align: center;
}
.nameGateIcon {
  width: 64px; height: 64px; margin: 0 auto 24px;
  display: flex; align-items: center; justify-content: center;
  background: var(--color-accent-soft); border-radius: 50%;
  color: var(--color-accent-purple);
  box-shadow: 0 0 0 1px rgba(131,40,249,0.12), 0 8px 24px -8px rgba(131,40,249,0.2);
}
.nameGateTitle { font-size: 28px; font-weight: 700; color: var(--color-text-primary); margin-bottom: 8px; letter-spacing: -0.01em; }
.nameGateDesc { color: var(--color-text-muted); font-size: 15px; margin-bottom: 32px; line-height: 1.5; }
.nameGateForm { display: flex; gap: 12px; }
.nameGateInput {
  flex: 1; background: var(--color-surface); border: 1px solid var(--color-border);
  border-radius: var(--radius-md); padding: 14px 18px;
  color: var(--color-text-primary); font-size: 16px;
  outline: none; transition: border-color 0.2s, box-shadow 0.2s;
}
.nameGateInput:focus { border-color: var(--color-accent-purple); box-shadow: 0 0 0 2px rgba(131,40,249,0.1); }

/* ================================================
   ANIMATIONS & EFFECTS (Global)
   ================================================ */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(16px); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-fade-in-up {
  animation: fadeInUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.stagger-1 { animation: fadeInUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; animation-delay: 0.05s; }
.stagger-2 { animation: fadeInUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; animation-delay: 0.1s; }
.stagger-3 { animation: fadeInUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; animation-delay: 0.15s; }
.stagger-4 { animation: fadeInUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; animation-delay: 0.2s; }
.stagger-5 { animation: fadeInUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; animation-delay: 0.25s; }

/* ================================================
   RESPONSIVE
   ================================================ */
@media (max-width: 768px) {
  .navLinks a:not(:last-child) { display: none; }
  .stepsGrid { grid-template-columns: 1fr; }
  .featuresGrid { grid-template-columns: 1fr; }
  .useCasesGrid { grid-template-columns: 1fr; }
  .trustGrid { grid-template-columns: repeat(2, 1fr); }
  .finalCta { padding: 56px 24px; }
  .nameGateForm { flex-direction: column; }
}
@media (max-width: 480px) {
  .trustGrid { grid-template-columns: 1fr; }
}
