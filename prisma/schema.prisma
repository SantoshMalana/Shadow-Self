// Shadow Shelf — Production Schema
// Stage 0: Personal companion MVP
//
// Key design decisions:
// - User.id matches Supabase auth.users.id (set on signup, not auto-generated)
// - pgvector (1536 dims) for real vector similarity search, replacing JSON-string embeddings
// - pgcrypto for server-side UUID generation via gen_random_uuid()
// - PersonalityProfile is versioned (keeps last N snapshots for rollback)
// - Cascade deletes on all FK → User for hard deletion support (Task 10)
// - Snake_case table/column names via @@map/@map (Postgres convention)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector", schema: "extensions"), pgcrypto(schema: "extensions")]
}

// ─── User ──────────────────────────────────────────────────────────────────────
// Linked to Supabase auth.users by UUID. Stores app-specific profile data.
// The id is NOT auto-generated — it's set to match the Supabase auth user ID on signup.

model User {
  id        String   @id @db.Uuid
  email     String   @unique
  name      String?
  depthRung Int      @default(1) @map("depth_rung") // Trust depth 1–5 (§5 of spec)
  daysKnown Int      @default(0) @map("days_known")
  apiKey    String?  @unique @map("api_key")         // For VS Code extension auth
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  messages            Message[]
  memories            Memory[]
  personalityProfiles PersonalityProfile[]
  consentEntries      ConsentLedger[]
  feedbacks           Feedback[]

  // Scout Relations
  personalBaselines    PersonalBaseline[]
  queuedFrictionEvents QueuedFrictionEvent[]
  scoutTrustLedgers    ScoutTrustLedger[]
  pipelineAuditLogs    PipelineAuditLog[]

  @@map("users")
}

// ─── PersonalityProfile ────────────────────────────────────────────────────────
// Versioned — keeps last N snapshots for rollback (§4 gap: versioning/rollback).
// Replaces the MVP's singleton Personality model.
// Uses native Json columns instead of JSON-encoded strings.

model PersonalityProfile {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String   @map("user_id") @db.Uuid
  version            Int      @default(1)
  sessions           Int      @default(0)
  communicationStyle Json?    @map("communication_style") // { tone[], vocabulary[], sentence_patterns[], explanation_style }
  thinkingPatterns   Json?    @map("thinking_patterns") // { decision_framework[], values[], opinions[], contrarian_positions[] }
  emotionalProfile   Json?    @map("emotional_profile") // { passion_topics[], frustration_triggers[], humor_style, empathy_markers[] }
  knowledgeDomains   Json?    @map("knowledge_domains") // string[]
  trainingExamples   Json?    @map("training_examples") // string[]
  voiceId            String?  @map("voice_id")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, version])
  @@index([userId, isActive])
  @@map("personality_profiles")
}

// ─── Message ───────────────────────────────────────────────────────────────────
// Chat messages. Mode expanded from train/clone to include onboarding and companion.
// turn_goal tracks the AI's determined goal for this turn (§5 determine_turn_goal).

model Message {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String // "user" or "assistant"
  content   String
  mode      String // "onboarding", "companion", "train", "clone"
  turnGoal  String?  @map("turn_goal")
  createdAt DateTime @default(now()) @map("created_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedbacks Feedback[]

  @@index([userId, createdAt])
  @@map("messages")
}

// ─── Memory ────────────────────────────────────────────────────────────────────
/// The vector dimension must match the embedding model's output exactly.
/// We are using Google AI Studio (gemini-embedding-2) truncated to 768 dimensions.
// Content is sanitized before storage to prevent stored injection (§4 gap).

model Memory {
  id        String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String                         @map("user_id") @db.Uuid
  content   String
  embedding Unsupported("vector(768)")?
  category  String?
  createdAt DateTime                       @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("memories")
}

// ─── ConsentLedger ─────────────────────────────────────────────────────────────
// Immutable, append-only log of per-stream consent decisions.
// Streams: "voice", "text", "memory", "personality"
// Supports the consent UI in Task 11.

model ConsentLedger {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  stream    String // "voice", "text", "memory", "personality"
  consented Boolean
  ipAddress String?  @map("ip_address")
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, stream])
  @@map("consent_ledger")
}

// ─── Feedback ──────────────────────────────────────────────────────────────────
// Thumbs up/down + optional correction text on each response (§4 gap: feedback UI).
// Powers the RLHF correction loop.

model Feedback {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  messageId      String   @map("message_id") @db.Uuid
  rating         String // "up" or "down"
  correctionText String?  @map("correction_text")
  createdAt      DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([messageId])
  @@map("feedback")
}

// ─── AnonymousCognitiveModel ───────────────────────────────────────────────────
// Stage 1: Zero Knowledge Distillation
// Completely anonymous table with no relation to User.
// Stores abstract problem-solving frameworks/intuitions extracted from sanitized chats.

model AnonymousCognitiveModel {
  id        String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  insight   String
  embedding Unsupported("vector(768)")?
  domain    String?
  createdAt DateTime                       @default(now()) @map("created_at")

  @@map("anonymous_cognitive_model")
}

// ─── Scout Models ──────────────────────────────────────────────────────────────
// Stage 2: Personal Anomaly Filter baseline
model PersonalBaseline {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  signalType  String   @map("signal_type") // e.g., 'idle_seconds', 'undo_ratio'
  mean        Float
  stddev      Float
  sampleCount Int      @map("sample_count")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, signalType])
  @@map("scout_personal_baselines")
}

// Stage 3: Workflow-Boundary Gate queue
model QueuedFrictionEvent {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  signalType String   @map("signal_type")
  detectedAt DateTime @default(now()) @map("detected_at")
  expiresAt  DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("scout_queued_events")
}

// Stage 6: Tiered Affordance Ledger
model ScoutTrustLedger {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  signalType String   @map("signal_type")
  tier       Int      @default(0) // 0: Silent, 1: Gutter icon, 2: Proactive voice

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, signalType])
  @@map("scout_trust_ledgers")
}

// Audit Framework: The pipeline log
model PipelineAuditLog {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                  String   @map("user_id") @db.Uuid
  signalType              String   @map("signal_type")
  stage1Raw               Json     @map("stage1_raw")
  stage2AnomalyScore      Float?   @map("stage2_anomaly_score")
  stage3BoundaryReached   String?  @map("stage3_boundary_reached")
  stage4StuckConfidence   Float?   @map("stage4_stuck_confidence")
  stage4ContentConfidence Float?   @map("stage4_content_confidence")
  stage5Verdict           String?  @map("stage5_verdict") // SHOW, HOLD, DISCARD
  finalOutcome            String   @map("final_outcome")
  userFeedback            String?  @map("user_feedback")
  timestamp               DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
  @@map("scout_pipeline_audit_logs")
}
